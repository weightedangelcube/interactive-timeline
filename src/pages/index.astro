---
import Layout from "../layouts/layout.astro";
import "../styles/main.scss"
import { X } from '@lucide/astro';
---

<Layout>
    <svg class="line" viewBox="0 0 1260 860">
        <defs>
            <linearGradient id="linear" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#04a5e5"/>
                <stop offset="33%" stop-color="#40a02b"/>
                <stop offset="66%" stop-color="#e64553"/>
            </linearGradient>
        </defs>
        <path stroke="url(#linear)" d="
            M 5, 5
            L 1205, 5
            Q 1255, 5
              1255, 55
            L 1255, 205
            Q 1255, 255
              1205, 255
            L 55, 255
            Q 5, 255
              5, 305
            L 5, 455
            Q 5, 505
              55, 505
            L 1205, 505
            Q 1255, 505
              1255, 555
            L 1255, 705
            Q 1255, 755
              1205, 755
            L 5, 755
        "></path>
    </svg>
    <div class="timeline-container">
        <div class="timeline">
            <div class="timeline-entry timeline-row-1" id="card-1-1"></div>
            <div class="timeline-entry timeline-row-1" id="card-1-2"></div>
            <div class="timeline-entry timeline-row-1" id="card-1-3"></div>
            <div class="timeline-entry timeline-row-1" id="card-1-4"></div>
            <div class="timeline-entry timeline-row-2" id="card-2-1"></div>
            <div class="timeline-entry timeline-row-2" id="card-2-2"></div>
            <div class="timeline-entry timeline-row-2" id="card-2-3"></div>
            <div class="timeline-entry timeline-row-2" id="card-2-4"></div>
            <div class="timeline-entry timeline-row-3" id="card-3-1"></div>
            <div class="timeline-entry timeline-row-3" id="card-3-2"></div>
            <div class="timeline-entry timeline-row-3" id="card-3-3"></div>
            <div class="timeline-entry timeline-row-3" id="card-3-4"></div>
        </div>
    </div>
    <div class="footer">
		<div class="legend">
			<p>legend: </p>
			<p>classical liberalism + capitalism</p>
			<p>reform + adaptation</p>
			<p>collectivism + socialism + communism</p>	
		</div>
    </div>
    <div class="modal">
        <div class="modal-popup">
            <X id="close-modal" />            
        </div>
    </div>

</Layout>